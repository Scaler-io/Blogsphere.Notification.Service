{
  "Logging": {
    "IncludeScopes": false,
    "LogOutputTemplate": "[{Timestamp:dd-MM-yyyy HH:mm:ss, fff}] {Level} {Properties} [CorrelationId:{CorrelationId}] [Machine: {MachineName}] {CallerType}:{MemberName} {Message}{NewLine}{Exception}{NewLine}",
    "Console": {
      "Enabled": true,
      "LogLevel": "Debug"
    },
    "Elastic": {
      "Enabled": false,
      "LogLevel": "Debug"
    }
  },
  "AppConfigurations": {
    "ApplicationIdentifier": "Blogsphere.Notification.Service",
    "ApplicationEnvironment": "Development",
    "NotificationProcessInterval": "30",
    "IntervalUnit": "ss"
  },
  "InfrastructureSettings": {
    "identityBaseUrl": "http://localhost:5000"
  },
  "Elasticsearch": {
    "Uri": "http://localhost:9200"
  },
  "EventBus": {
    "Host": "localhost",
    "Username": "guest",
    "Password": "guest",
    "VirtualHost": "/"
  },
  "EmailTemplates": {
    "UserInvite": "UserInvitationSent",
    "AuthCodeSent": "AuthCodeSent",
    "PasswordResetInstructionSent": "PasswordResetInstructionSent",
    "ManagementUserWelcomeEmailSent": "ManagementUserWelcomeEmailSent",
    "ManagementUserPasswordEmailSent": "ManagementUserPasswordEmailSent"
  },
  "EmailSettings": {
    "Server": "sandbox.smtp.mailtrap.io",
    "Port": 587,
    "CompanyAddress": "support@blogsphere",
    "UserName": "<your-mailtrap-username>",
    "Password": "<your-mailtrap-password>"
  },
  "ConnectionStrings": {
    "AzureTableStorage": "DefaultEndpointsProtocol=http;AccountName=<account-name>;AccountKey=<account-key>;TableEndpoint=http://127.0.0.1:21002/<account-name>;",
    "BlobStorage": "DefaultEndpointsProtocol=http;AccountName=<account-name>;AccountKey=<account-key>;BlobEndpoint=http://127.0.0.1:21000/<account-name>;"
  },
  "Zipkin": {
    "Url": "http://localhost:9411/api/v2/spans"
  },
  "Jaeger": {
    "Host": "localhost",
    "Port": 6831
  }
}
